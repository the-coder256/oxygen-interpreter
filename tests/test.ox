define hello() {
    print("Hello, world!")
    x = 25             // Only available here
    return x
}

x = 2                  // Sets variable 'x' to 2
print(x)               // Prints value of 'x'

if x == 1 {
    print("x is 1")
} else if x == 2 {
    print("x is 2")
} else if x == 3 {
    print("x is 3")
} else {
    print("x is not 1, 2 or 3")
}

